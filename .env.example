# ============================================================
# FDS Command Hub — environment contract
# Copy to .env for local dev:  cp .env.example .env
# In production, set these in Vercel → Project → Settings →
# Environment Variables. NEVER commit real secrets.
# ============================================================

# ---- Stage 0: Database (required) --------------------------
# Local dev default is a SQLite file (zero setup). For production
# use Neon or Vercel Postgres and ALSO flip `provider` to
# "postgresql" in prisma/schema.prisma (see README → Database).
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ---- Stage 3: Shopify -----------------------------------------
# Domain is the store's *.myshopify.com host (already known for FDS).
# Credentials: Dev Dashboard (dev.shopify.com) → "FDS Command Hub"
# app → Settings → Client ID + Client secret. The app exchanges them
# for 24h Admin tokens automatically (client credentials grant).
# App scopes: read_products, read_orders, read_customers.
SHOPIFY_STORE_DOMAIN="gthv54-e1.myshopify.com"
# SHOPIFY_CLIENT_ID=""
# SHOPIFY_CLIENT_SECRET=""
# Legacy alternative (admin-created custom apps only):
# SHOPIFY_ADMIN_TOKEN="shpat_..."

# ---- Stage 4: Comms (human supplies) ------------------------
# Discord: create an app + bot at discord.com/developers.
# DISCORD_BOT_TOKEN=""
# DISCORD_WEBHOOK_URL=""
# DISCORD_CHANNEL_IDS=""            # comma-separated channel IDs

# Google OAuth client (Gmail + Calendar scopes), from Google
# Cloud Console → APIs & Services → Credentials.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---- Stage 5: Agent harness (human supplies) ----------------
# ANTHROPIC_API_KEY=""              # Claude Code harness
# OPENAI_API_KEY=""                 # Codex harness

# ---- HQ engine: agent API access -----------------------------
# Bearer token the Claude agent (PM / workers) uses to read/write
# hub data through /api/*. Generate any long random string, e.g.:
#   openssl rand -hex 32
# AGENT_API_KEY=""

# ---- Team access gate (production; src/proxy.ts) --------------
# Shared credentials for the deployed HQ. Unset = gate off (local
# dev). The team signs in once per browser via the native prompt.
# TEAM_USER="fds"
# TEAM_PASSWORD=""

# ---- Stage 7: Auth (human supplies) -------------------------
# Generate with: npx auth secret
# AUTH_SECRET=""
